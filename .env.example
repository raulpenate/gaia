# ─────────────────────────────────────────────────────────────
# Gaia — Soil Health Platform
# Copy this file to `.env.local` and fill in the values you need.
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── External data providers ──────────────────────────────────

# Open-Meteo — free tier needs no key. Set this only if you have a
# commercial subscription; the client will switch to customer-api.open-meteo.com.
# OPEN_METEO_API_KEY=

# AgroMonitoring (OpenWeather) — required for NDVI / satellite imagery.
# Get one at https://agromonitoring.com/
AGRO_API_KEY=

# NASA POWER — no key required.

# ── Future buckets (uncomment as features land) ──────────────
# DB_URL=
# AI_API_KEY=
