# ─────────────────────────────────────────────────────────────
# Gaia — Soil Health Platform
# Copy this file to `.env.local` and fill in the values you need.
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Satellite / soil APIs ────────────────────────────────────
# Open-Meteo requires no key.
# OpenWeatherMap Agro: sign up at https://agromonitoring.com — free tier ~5k req/day.
OPENWEATHER_AGRO_API_KEY=
# NASA FIRMS: request a MAP_KEY at https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_MAP_KEY=

# ── Future buckets (uncomment as features land) ──────────────
# DB_URL=
# AI_API_KEY=
